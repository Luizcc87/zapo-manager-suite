# Copie este arquivo para .env e preencha os valores antes do deploy.
# Gerar GLOBAL_API_KEY:   openssl rand -hex 32
# Gerar POSTGRES_PASSWORD: openssl rand -base64 24
#
# Deploy:
#   export $(cat .env | xargs) && docker stack deploy -c docker-stack-swarm.yaml zapo --with-registry-auth

GLOBAL_API_KEY=
POSTGRES_PASSWORD=
SERVER_URL=https://zapo.seu-dominio.com
WEBHOOK_URL=
