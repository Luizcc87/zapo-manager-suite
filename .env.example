# Copie este arquivo para .env e preencha os valores antes do deploy.
# Gerar GLOBAL_API_KEY:   openssl rand -hex 32
# Gerar POSTGRES_PASSWORD: openssl rand -base64 24
#
# Deploy:
#   export $(cat .env | xargs) && docker stack deploy -c docker-stack-swarm.yaml zapo --with-registry-auth

GLOBAL_API_KEY=
POSTGRES_PASSWORD=
SERVER_URL=https://zapo.seu-dominio.com
WEBHOOK_URL=
TEST_CONNECTED_INSTANCE=test-4
TEST_TARGET_NUMBER=5555999703107

# URL de conexão com o banco Postgres (local ou container)
DATABASE_URL=postgresql://zapo_user:zapo_pass@localhost:5432/zapo_db?schema=public

# URL de conexão com o Redis para controle de locks e concorrência
REDIS_URL=redis://localhost:6379/0

# Persistência de Dados (defina como true para ativar o armazenamento no banco de dados)
SAVE_DATA_NEW_MESSAGE=false
SAVE_DATA_CONTACTS=true
SAVE_DATA_HISTORIC=false

