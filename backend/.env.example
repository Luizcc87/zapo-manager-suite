PORT=8080
GLOBAL_API_KEY=global_key
DATABASE_URL=postgresql://zapo_user:zapo_pass@localhost:5432/zapo_db?schema=public
REDIS_URL=redis://localhost:6379/0
# WEBHOOK_URL=http://localhost:3000/webhook

# ── PERSISTÊNCIA DE DADOS ────────────────────────────────────────────────────
# Controla quais dados são salvos no banco PostgreSQL além da sessão.
# Requer DATABASE_URL apontando para PostgreSQL (não SQLite).
# false = dados ficam só em RAM e são perdidos ao reiniciar.
SAVE_DATA_NEW_MESSAGE=false
SAVE_DATA_CONTACTS=false
SAVE_DATA_HISTORIC=false

