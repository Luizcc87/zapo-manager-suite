datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Instance {
  id              String   @id @default(cuid())
  instanceName    String   @unique
  apiKey          String
  status          String   @default("disconnected")
  mobileTransport Boolean  @default(false)
  registeredPhone String?
  deviceInfo      Json?
  settingsConfig  Json?
  webhookConfig   Json?
  proxyConfig     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Persiste a lista de chats por instância para sobreviver a restarts.
model ChatEntry {
  id           String   @id @default(cuid())
  instanceName String
  remoteJid    String
  pushName     String   @default("")
  profilePicUrl String  @default("")
  labels       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([instanceName, remoteJid])
  @@map("wa_chats")
}
