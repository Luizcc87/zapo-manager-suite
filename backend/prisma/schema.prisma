datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Instance {
  id              String   @id @default(cuid())
  instanceName    String   @unique
  apiKey          String
  status          String   @default("disconnected")
  mobileTransport Boolean  @default(false)
  registeredPhone String?
  deviceInfo      Json?
  settingsConfig  Json?
  webhookConfig   Json?
  proxyConfig     Json?
  profilePicUrl   String   @default("")
  profileName     String   @default("")
  ownerJid        String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Persiste mensagens por instância quando SAVE_DATA_NEW_MESSAGE=true.
model Message {
  id               String   @id @default(cuid())
  instanceName     String
  remoteJid        String
  messageId        String
  fromMe           Boolean  @default(false)
  pushName         String   @default("")
  messageType      String   @default("unknown")
  message          Json?
  messageTimestamp String
  source           String   @default("baileys")
  createdAt        DateTime @default(now())

  @@unique([instanceName, messageId])
  @@index([instanceName, remoteJid])
  @@map("wa_messages")
}

/// Persiste a lista de chats por instância para sobreviver a restarts.
model ChatEntry {
  id           String   @id @default(cuid())
  instanceName String
  remoteJid    String
  pushName     String   @default("")
  profilePicUrl String  @default("")
  labels       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([instanceName, remoteJid])
  @@map("wa_chats")
}

/// Persiste o estado de época do host de companions para instâncias Mobile Primary.
/// rawId + currentKeyIndex garantem que o keyIndex não seja reemitido após restart.
model WaCompanionHostEpoch {
  id              String   @id @default(cuid())
  instanceName    String   @unique @map("instance_name")
  rawId           Int      @map("raw_id")
  currentKeyIndex Int      @map("current_key_index")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  companions WaCompanionDevice[]

  @@map("wa_companion_host_epoch")
}

/// Um companion (ex: WhatsApp Web) pareado a esta instância Mobile Primary.
model WaCompanionDevice {
  id                          String   @id @default(cuid())
  instanceName                String   @map("instance_name")
  deviceJid                   String   @map("device_jid")
  keyIndex                    Int      @map("key_index")
  companionIdentityPublicKey  Bytes    @map("companion_identity_public_key")
  addedAtSeconds              Int      @map("added_at_seconds")
  createdAt                   DateTime @default(now()) @map("created_at")

  epoch WaCompanionHostEpoch @relation(fields: [instanceName], references: [instanceName], onDelete: Cascade)

  @@unique([instanceName, deviceJid])
  @@map("wa_companion_devices")
}

